  "mesh_hotspots": [
    {
      "id": "mund",
      "knoten": [
        "mouth"
      ],
      "titel": "Mund / Mundhöhle",
      "text": "Im Mund beginnt die Verdauung. Die Zähne zerkleinern die Nahrung mechanisch, der Speichel durchfeuchtet sie und macht sie gleitfähig. Das Enzym Amylase im Speichel spaltet erste Stärke schon hier in Zuckerbausteine. Die Zunge formt den zerkauten Bissen und schiebt ihn zum Schlucken nach hinten.",
      "label": "Mundhöhle",
      "farbe": "#ff9c6b",
      "kapitel": "mund"
    },
    {
      "id": "speiseroehre",
      "knoten": [
        "esophagus"
      ],
      "titel": "Speiseröhre",
      "text": "Die Speiseröhre ist ein etwa 25 cm langer Muskelschlauch zwischen Rachen und Magen. Wellenförmige Muskelbewegungen, die Peristaltik, schieben den Bissen aktiv abwärts. Der Transport gelingt dadurch auch unabhängig von der Schwerkraft.",
      "label": "Speiseröhre",
      "farbe": "#e8b25a",
      "kapitel": "speiseroehre"
    },
    {
      "id": "magen",
      "knoten": [
        "stomach"
      ],
      "titel": "Magen",
      "text": "Der Magen sammelt die Nahrung und durchmischt sie mit saurem Magensaft. Die Salzsäure tötet viele Keime ab, das Enzym Pepsin beginnt mit der Spaltung von Eiweißen. Portionsweise gibt der Magenpförtner den entstandenen Speisebrei an den Dünndarm weiter.",
      "label": "Magen",
      "farbe": "#ff7a5c",
      "kapitel": "magen"
    },
    {
      "id": "duenndarm",
      "knoten": [
        "small_intestine"
      ],
      "titel": "Dünndarm",
      "text": "Der Dünndarm ist mit rund sechs Metern der längste Abschnitt und der Hauptort der Verdauung. Enzyme aus Bauchspeicheldrüse und Darmwand zerlegen Kohlenhydrate, Fette und Eiweiße in kleinste Bausteine. Über unzählige Zotten der Darmwand gelangen diese Nährstoffe ins Blut.",
      "label": "Dünndarm",
      "farbe": "#ff6f91",
      "kapitel": "duenndarm"
    },
    {
      "id": "dickdarm",
      "knoten": [
        "large_intestine"
      ],
      "titel": "Dickdarm",
      "text": "Im Dickdarm werden dem unverdaulichen Rest Wasser und Salze entzogen, sodass der Inhalt eindickt. Zahlreiche Darmbakterien bauen Reste ab und bilden dabei einige Vitamine. Der eingedickte Stuhl wird zum Enddarm weitergeschoben.",
      "label": "Dickdarm",
      "farbe": "#b07ae0",
      "kapitel": "dickdarm"
    },
    {
      "id": "enddarm",
      "knoten": [
        "rectum"
      ],
      "titel": "Enddarm",
      "text": "Der Enddarm speichert den Stuhl bis zur Ausscheidung. Ein Schließmuskel hält ihn zurück und ermöglicht die kontrollierte Entleerung über den After. Damit endet der Weg der Nahrung durch den Verdauungstrakt.",
      "label": "Enddarm",
      "farbe": "#6fa8d0",
      "kapitel": "enddarm"
    }
  ]
}